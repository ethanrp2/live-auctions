# Live Auctions — frontend (Next.js) env example
#
# Copy to .env.local and fill in real values. Never commit .env.local.
# See docs/memory/architecture/tenant-model.md for how these are used.

# ---- Supabase ----
# Project URL + publishable (anon) key. Get from https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# ---- Multi-tenant routing ----
# Root domain (no leading dot). proxy.ts extracts subdomains relative to this.
# Local: localhost. Staging: staging.liveauctions.com. Prod: liveauctions.com.
# Must match the cookie domain used by Supabase auth so sessions work cross-subdomain.
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# ---- Backend ----
# Fastify server URL the frontend calls for Basta tokens, seller CRUD, etc.
# Local default 4000; staging/prod should be the deployed backend URL.
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ---- Basta client (M1+) ----
# Not required for the static storefront. Needed from M1 for real bidding.
# NEXT_PUBLIC_BASTA_CLIENT_URL=https://client.api.basta.app/graphql
# NEXT_PUBLIC_BASTA_WS_URL=wss://client.api.basta.app/query
