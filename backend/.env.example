# Live Auctions — backend (Fastify) env example
#
# Copy to backend/.env and fill in real values. Never commit backend/.env.
# See docs/memory/architecture/basta-integration.md for how Basta vars are used.

# ---- Fastify server ----
PORT=4000
CORS_ORIGIN=http://localhost:3000
ROOT_DOMAIN=localhost

# ---- Supabase ----
# Same project URL as the frontend.
SUPABASE_URL=https://<your-project-ref>.supabase.co
# SERVICE ROLE key bypasses RLS. Used for: admin user creation, webhook-driven
# INSERTs to orders/bids/webhook_events, updates that no RLS policy allows.
# NEVER expose this to the frontend. NEVER commit it.
# Get from https://supabase.com/dashboard/project/<ref>/settings/api (Project API keys → service_role).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Basta ----
# Management API GraphQL endpoint.
BASTA_MANAGEMENT_API_URL=https://management.api.basta.app/graphql
# Account ID + API key. One shared account across all tenants (see ADR-001).
# Get from https://basta.app/ dashboard → Settings → API.
BASTA_ACCOUNT_ID=
BASTA_API_KEY=
# Bidder token TTL in minutes. 60 is fine for dev; bump to 180 for long auctions.
BASTA_BIDDER_TOKEN_TTL_MINUTES=60
# Default lot-open window in milliseconds. Each lot's openDate is staggered by this
# from the auction scheduled_date. 3_600_000 = 1 hour per lot.
BASTA_LOT_DURATION_MS=3600000

# ---- Signed uploads ----
# TTL for signed upload URLs on lot images.
SIGNED_UPLOAD_EXPIRES_IN_SECONDS=1800

# ---- M2 (webhooks — shipped) ----
# Shared-secret gate for POST /api/webhooks/basta. If set, the webhook
# handler requires header `x-basta-secret: <this value>` on every delivery.
# Configure the same value in the Basta admin portal webhook header config.
# Stopgap until Basta publishes the signature verification spec (open Q5 in
# docs/memory/risks/basta-questions.md).
# BASTA_WEBHOOK_SECRET=
# When Basta's signature spec is answered, replace BASTA_WEBHOOK_SECRET with:
# BASTA_WEBHOOK_SIGNING_SECRET=

# ---- M6+ (Stripe) ----
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CONNECT_CLIENT_ID=
# PLATFORM_FEE_BPS=500              # 5% default per ADR-005 (pending).

# ---- M7+ (LiveKit) ----
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://<your-project>.livekit.cloud

# ---- M8+ (Twilio) ----
# Keep false until Twilio phone verification/A2P is complete.
SMS_ENABLED=false
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
